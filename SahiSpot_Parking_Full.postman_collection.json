{
  "info": {
    "name": "SahiSpot Parking — Full API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete Postman collection for SahiSpot Parking Management SaaS backend. All parking routes are under /api/v1/parking."
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:8082" },
    { "key": "locationId",  "value": "1" },
    { "key": "slotId",      "value": "1" },
    { "key": "bookingId",   "value": "1" },
    { "key": "paymentId",   "value": "1" },
    { "key": "reviewId",    "value": "1" },
    { "key": "imageId",     "value": "1" },
    { "key": "adminId",     "value": "1" }
  ],
  "item": [
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/health" }
        },
        {
          "name": "Root",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/" }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Signup — Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/signup"
          }
        },
        {
          "name": "Signup — Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/verify-otp"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/resend-otp"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/login"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "header": [], "url": "{{baseUrl}}/api/v1/logout" }
        }
      ]
    },
    {
      "name": "🔑 Forgot Password",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\"\n}" },
            "url": "{{baseUrl}}/api/v1/forgot-password"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\"\n}" },
            "url": "{{baseUrl}}/api/v1/forgot-password/resend"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": "{{baseUrl}}/api/v1/forgot-password/verify-otp"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"newPassword\": \"NewStrongPass123\"\n}" },
            "url": "{{baseUrl}}/api/v1/forgot-password/reset"
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/profile" }
        },
        {
          "name": "Edit Profile",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "img", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/v1/profile/edit"
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123\"\n}" },
            "url": "{{baseUrl}}/api/v1/admin/login"
          }
        },
        {
          "name": "Admin Logout",
          "request": { "method": "POST", "header": [], "url": "{{baseUrl}}/api/v1/admin/logout" }
        },
        {
          "name": "Create Admin (Super Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Admin 2\",\n  \"email\": \"admin2@example.com\",\n  \"password\": \"AdminPass456\"\n}" },
            "url": "{{baseUrl}}/api/v1/admin/create"
          }
        },
        {
          "name": "List Admins",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/admin/list" }
        },
        {
          "name": "All Users",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/admin/allUser" }
        },
        {
          "name": "Delete Admin",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/api/v1/admin/{{adminId}}" }
        }
      ]
    },
    {
      "name": "📍 Locations",
      "item": [
        {
          "name": "Get Nearby Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/locations/nearby?lat=28.6139&lng=77.2090&radius=10&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "locations", "nearby"],
              "query": [
                { "key": "lat", "value": "28.6139" },
                { "key": "lng", "value": "77.2090" },
                { "key": "radius", "value": "10" },
                { "key": "city", "value": "", "disabled": true },
                { "key": "type", "value": "car", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get All Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/locations?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "locations"],
              "query": [
                { "key": "city", "value": "Delhi", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Location by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}"
          }
        },
        {
          "name": "Create Location  [owner]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"SahiSpot Parking Hub\",\n  \"description\": \"Secure underground parking\",\n  \"address\": \"12 Main Street, Connaught Place\",\n  \"city\": \"New Delhi\",\n  \"state\": \"Delhi\",\n  \"latitude\": 28.6315,\n  \"longitude\": 77.2167\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/locations"
          }
        },
        {
          "name": "Update Location  [owner]",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"SahiSpot Parking Hub (Updated)\",\n  \"description\": \"Renovated secure parking\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}"
          }
        },
        {
          "name": "Delete Location  [owner]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}"
          }
        }
      ]
    },
    {
      "name": "🚗 Parking Slots",
      "item": [
        {
          "name": "Get Slots by Location",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/slots",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "locations", "{{locationId}}", "slots"],
              "query": [
                { "key": "type", "value": "car", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Single Slot  [owner]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slot_number\": \"A-01\",\n  \"type\": \"car\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/slots"
          }
        },
        {
          "name": "Create Bulk Slots  [owner]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slots\": [\n    { \"slot_number\": \"A-01\", \"type\": \"car\" },\n    { \"slot_number\": \"A-02\", \"type\": \"car\" },\n    { \"slot_number\": \"B-01\", \"type\": \"bike\" },\n    { \"slot_number\": \"E-01\", \"type\": \"ev\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/slots/bulk"
          }
        },
        {
          "name": "Update Slot  [owner]",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"ev\",\n  \"is_available\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/slots/{{slotId}}"
          }
        },
        {
          "name": "Delete Slot  [owner]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/slots/{{slotId}}"
          }
        }
      ]
    },
    {
      "name": "📅 Bookings",
      "item": [
        {
          "name": "Create Booking  [user]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slot_id\": 1,\n  \"location_id\": 1,\n  \"start_time\": \"2026-03-27T10:00:00\",\n  \"end_time\": \"2026-03-27T13:00:00\",\n  \"price_per_hour\": 50\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/bookings"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/bookings/my?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "bookings", "my"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/bookings/{{bookingId}}/cancel"
          }
        },
        {
          "name": "Complete Booking  [admin/owner]",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/bookings/{{bookingId}}/complete"
          }
        }
      ]
    },
    {
      "name": "💳 Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": 1,\n  \"payment_method\": \"online\",\n  \"transaction_id\": \"TXN_ABC123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/payments"
          }
        },
        {
          "name": "My Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/payments/my?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "payments", "my"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Payment by Booking",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/payments/booking/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "⭐ Reviews",
      "item": [
        {
          "name": "Get Reviews for Location",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/reviews?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "locations", "{{locationId}}", "reviews"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Add Review  [auth]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent parking facility, very safe and clean!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/reviews"
          }
        },
        {
          "name": "Delete Review  [auth]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/reviews/{{reviewId}}"
          }
        }
      ]
    },
    {
      "name": "❤️ Favorites",
      "item": [
        {
          "name": "My Favorites",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/parking/favorites?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parking", "favorites"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Toggle Favorite  [auth]",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/favorites/{{locationId}}"
          }
        }
      ]
    },
    {
      "name": "🖼️ Parking Images",
      "item": [
        {
          "name": "Get Images for Location",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/images"
          }
        },
        {
          "name": "Upload Image  [owner]  (multipart/form-data)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/images"
          }
        },
        {
          "name": "Delete Image  [owner]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/parking/locations/{{locationId}}/images/{{imageId}}"
          }
        }
      ]
    },
    {
      "name": "📬 Contact",
      "item": [
        {
          "name": "Contact Us",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"message\": \"I need help with my booking.\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/contact/"
          }
        }
      ]
    }
  ]
}
